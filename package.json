{
  "name": "@wolpertingerlabs/callboard",
  "version": "1.0.0-alpha.13.0",
  "description": "A web-based control panel for managing Claude Code sessions, autonomous agents, and multi-agent workflows",
  "license": "MIT",
  "type": "module",
  "main": "./backend/dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/WolpertingerLabs/callboard.git"
  },
  "homepage": "https://github.com/WolpertingerLabs/callboard#readme",
  "bugs": {
    "url": "https://github.com/WolpertingerLabs/callboard/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai-agents",
    "agent-sdk",
    "multi-agent",
    "mcp",
    "model-context-protocol",
    "control-panel",
    "dashboard",
    "automation",
    "cron",
    "webhooks",
    "callboard"
  ],
  "bin": {
    "callboard": "./bin/callboard.js"
  },
  "files": [
    "backend/dist",
    "backend/src/scaffold",
    "frontend/dist",
    "shared/dist",
    "bin",
    "README.md",
    "!**/*.test.*",
    "!**/*.js.map",
    "!**/*.d.ts.map"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "CALLBOARD_DATA_DIR=$HOME/.callboard-dev concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "CALLBOARD_DATA_DIR=$HOME/.callboard-dev npm -w callboard-backend run dev",
    "dev:frontend": "CALLBOARD_DATA_DIR=$HOME/.callboard-dev npm -w callboard-frontend run dev",
    "swagger": "tsx backend/src/swagger.ts",
    "prebuild": "npm run swagger",
    "clean": "rm -rf shared/dist backend/dist frontend/dist shared/tsconfig.tsbuildinfo backend/tsconfig.tsbuildinfo frontend/tsconfig.tsbuildinfo",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend",
    "build:shared": "npm -w shared run build",
    "build:backend": "npm -w callboard-backend run build",
    "build:frontend": "npm -w callboard-frontend run build",
    "start": "NODE_ENV=production node backend/dist/index.js",
    "preview": "npm -w callboard-frontend exec vite preview",
    "lint": "git diff --name-only --cached HEAD | grep -E '\\.(js|jsx|ts|tsx)$' | xargs -r eslint",
    "lint:fix": "git diff --name-only --cached HEAD | grep -E '\\.(js|jsx|ts|tsx)$' | xargs -r eslint --fix",
    "lint:all": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:all:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "prettier": "git diff --name-only HEAD | xargs -r npx prettier --write --ignore-unknown && git diff --name-only --cached HEAD | xargs -r npx prettier --write --ignore-unknown",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "prepublishOnly": "npm run drawlatch:check && npm run lint:all && npm test && npm run build",
    "publish:dry-run": "npm publish --dry-run",
    "reload": "node scripts/drawlatch-reload.cjs",
    "drawlatch:local": "node scripts/drawlatch-switch.cjs local && npm install",
    "drawlatch:prod": "node scripts/drawlatch-switch.cjs prod && npm install",
    "drawlatch:which": "node scripts/drawlatch-switch.cjs which",
    "drawlatch:check": "node scripts/drawlatch-switch.cjs check"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.32",
    "@wolpertingerlabs/drawlatch": "^1.0.0-alpha.12.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron-parser": "^5.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/eslint__js": "^8.42.3",
    "concurrently": "^9.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "rollup": "^4.60.1",
    "swagger-autogen": "^2.23.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  }
}
